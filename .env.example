# ============================================================
# SOFIA 2.0 — .env.example
# Copia este archivo a `.env` y rellena los valores.
# `.env` está en .gitignore — nunca lo commitees.
# ============================================================

# --- Entorno ---
ENV=development                          # development | production
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR
APP_HOST=0.0.0.0
APP_PORT=8000

# --- LLM principales ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx    # console.anthropic.com → API Keys
ANTHROPIC_MODEL_PRINCIPAL=claude-haiku-4-5
ANTHROPIC_MODEL_JUEZ=claude-sonnet-4-6   # para golden tests
OPENAI_API_KEY=sk-xxxxxxxxxxxx
OPENAI_MODEL_AUXILIAR=gpt-4o-mini        # clasificación, extractor, vision
OPENAI_MODEL_EMBEDDINGS=text-embedding-3-small
OPENAI_EMBEDDING_DIM=1536

# --- Supabase ---
SUPABASE_URL=https://rugchqrjuxjqhdcfohby.supabase.co
SUPABASE_ANON_KEY=                       # Dashboard → API → anon key
SUPABASE_SERVICE_KEY=                    # Dashboard → API → service_role key
SUPABASE_DB_URL=                         # Dashboard → Database → Connection string (URI)
                                         # Formato: postgresql://postgres:[PASSWORD]@db.xxx.supabase.co:5432/postgres

# --- Redis ---
REDIS_URL=redis://localhost:6379/0       # dev local; en prod cambia a la URL del Redis del VPS
REDIS_DEBOUNCE_WINDOW_SECONDS=7

# --- Canales: Telegram ---
TELEGRAM_BOT_TOKEN=                      # @BotFather → /newbot
TELEGRAM_WEBHOOK_SECRET=                 # secret para validar X-Telegram-Bot-Api-Secret-Token

# --- Canales: Evolution API (WhatsApp) ---
EVOLUTION_BASE_URL=                      # ej. https://maple-ai-evolution-api.cxjnjn.easypanel.host
EVOLUTION_INSTANCE=                      # nombre de la instancia (QA y prod tendrán distintas)
EVOLUTION_API_KEY=                       # apikey de la instancia

# --- Canales: Web Chat ---
WEB_SESSION_COOKIE=sofia_web_session
WEB_CHAT_TITLE="Sofía — Maple Collège"

# --- Admin / Observabilidad ---
ADMIN_API_KEY=                           # secret para endpoints /admin/*
ALERT_DAILY_COST_USD=5.0
ALERT_P95_LATENCY_MS=15000

# --- Google Calendar (Block 4) ---
GOOGLE_CALENDAR_ID=admisiones@maplesaltillo.com
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# --- Feature flags ---
ENABLE_PROMPT_CACHING=true
ENABLE_VALIDATORS=true
MAX_REGENERATIONS_PER_TURN=2
